    @pytest.mark.asyncio
    async def test_update_quantity_same_unit(self):
        """Test updating quantity with same unit scales nutrition proportionally."""
        # Arrange
        mock_nutrition_service = Mock()
        strategy = UpdateFoodItemStrategy(mock_nutrition_service)
        
        food_items_dict = {
            "item1": FoodItem(
                id="item1",
                name="Chicken",
