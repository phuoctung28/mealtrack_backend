        """Should extract IP from X-Forwarded-For header."""
        client = TestClient(app)
        
        response = client.get(
            "/test",
            headers={"X-Forwarded-For": "1.2.3.4, 5.6.7.8"}
        )
        
        assert response.status_code == 200
