                id=str(uuid4()),
                name="Brown rice",
                quantity=200,
                unit="g",

                macros=Macros(protein=5, carbs=46, fat=1.8)
            ),
        ]

    @pytest.mark.asyncio
    async def test_translate_meal_skips_english(self, translation_service, sample_meal, sample_food_items):
        """Test that English translation is skipped."""
