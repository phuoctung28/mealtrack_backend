        # Arrange & Act & Assert
        with pytest.raises(ValidationError):
            FoodItemChangeRequest(
                action="invalid_action",
                name="Test Food",
                quantity=100.0,
                unit="g"
            )
    
    def test_negative_quantity(self):
        """Test negative quantity validation."""
        # Arrange & Act & Assert
        with pytest.raises(ValidationError):
            FoodItemChangeRequest(
                action="add",
                name="Test Food",
                quantity=-50.0,
                unit="g"
            )
    
    def test_zero_quantity(self):
