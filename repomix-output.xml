    @pytest.fixture
    def sample_food_items(self):
        """Create sample food items for testing."""
        return [
            FoodItem(
                id=str(uuid4()),
                name="Chicken breast",
                quantity=150,
                unit="g",

                macros=Macros(protein=31, carbs=0, fat=3.6)
            ),
