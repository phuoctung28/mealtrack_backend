        test_session.commit()
        
        # Test: 2:00 UTC = 9:00 AM Vietnam (should match)
        repository = NotificationRepository(db=test_session)
        current_utc = datetime(2024, 12, 7, 2, 0, tzinfo=timezone.utc)
