            ],
            prep_time_minutes=20,
            calories=450,
            protein=45.5,
            carbs=25.0,
            fat=18.0
        )
        assert not hasattr(response, 'description'), "Response should not have description field"
        assert len(response.ingredients) == 3
        assert len(response.recipe_steps) == 3
