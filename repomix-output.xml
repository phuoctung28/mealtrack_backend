        self.uow = uow

    async def handle(self, query: GetCheatDaysQuery) -> Dict[str, Any]:
        uow = self.uow or UnitOfWork()
        with uow:
            target_date = query.week_of or date.today()
            week_start = get_user_monday(target_date, query.user_id, uow)
