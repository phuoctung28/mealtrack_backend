[importlinter:contract:infra-no-app-api]
name = Infra does not import app or api
type = forbidden
source_modules =
    src.infra
forbidden_modules =
    src.app
    src.api
unmatched_ignore_imports_alerting = none
ignore_imports =
    src.infra.database.models.user.user -> src.api.schemas.common.auth_enums
    src.infra.event_bus.pymediator_event_bus -> src.api.exceptions

[importlinter:contract:api-no-infra]
name = API does not import infra directly
type = forbidden
source_modules =
    src.api
forbidden_modules =
    src.infra
# Indirect api -> app -> infra chains (the event bus registers app handlers that
# use infra) are normal layering; only DIRECT api -> infra imports are gated.
allow_indirect_imports = True
unmatched_ignore_imports_alerting = none
ignore_imports =
    src.api.base_dependencies -> src.infra.adapters.cloudinary_image_store
    src.api.base_dependencies -> src.infra.adapters.deepl_translation_adapter
    src.api.base_dependencies -> src.infra.adapters.fat_secret_service
