[importlinter]
# IMPORTANT: every package directory under src/ MUST contain an __init__.py.
# Without it, grimp drops the package from the import graph and every contract
# passes as a false-green (this masked the violations now baselined below).
#
# The ignore_imports lists freeze the pre-existing layering debt so CI blocks any
# NEW cross-layer import. The domain-isolation contract has no baseline and must
# stay clean. Shrink the other baselines as the debt is inverted behind ports.
root_packages =
    src
include_external_packages = True

[importlinter:contract:domain-isolation]
name = Domain has no external I/O dependencies
type = forbidden
source_modules =
    src.domain
forbidden_modules =
    src.infra
    src.app
    src.api
    httpx
    sqlalchemy
    redis
    firebase_admin

[importlinter:contract:app-no-infra]
name = App layer does not import infra directly
type = forbidden
source_modules =
    src.app
forbidden_modules =
    src.infra
unmatched_ignore_imports_alerting = none
ignore_imports =
    src.app.handlers.command_handlers.add_weight_entry_command_handler -> src.infra.database.uow_async
    src.app.handlers.command_handlers.complete_onboarding_command_handler -> src.infra.database.uow_async
    src.app.handlers.command_handlers.delete_fcm_token_command_handler -> src.infra.database.uow_async
    src.app.handlers.command_handlers.delete_hydration_entry_command_handler -> src.infra.database.uow_async
