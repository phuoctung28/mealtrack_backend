# ---------------------------------------------------------------------------
# General application settings
# ---------------------------------------------------------------------------
ENVIRONMENT=development
# Dev-only Firebase auth bypass. Requires BOTH ENVIRONMENT=development AND this
# flag = 1 (defense-in-depth: a stray ENVIRONMENT in prod alone can't disable auth).
ENABLE_DEV_AUTH_BYPASS=1
FAIL_ON_MIGRATION_ERROR=false
FAIL_ON_CACHE_ERROR=false
AUTO_MIGRATE=true
MIGRATION_TIMEOUT=60
MIGRATION_RETRY_ATTEMPTS=3
MIGRATION_RETRY_DELAY=2.0

# Comma-separated emails allowed to call privileged endpoints (feature-flag
# mutations). Empty = nobody can mutate flags (fail-closed).
ADMIN_EMAILS=

# Shared service token for infra monitoring endpoints (health pool/connection
# stats, cache metrics). Scrapers send it as the X-Monitoring-Token header.
MONITORING_API_TOKEN=

# ---------------------------------------------------------------------------
# Neon PostgreSQL
# Get from https://console.neon.tech → your project → Connection Details
#
# APP_DATABASE_URL: app runtime URL (preferred: direct endpoint for production).
# DATABASE_URL_DIRECT: direct URL for Alembic migrations ONLY (not used by app).
# DATABASE_URL: backward-compat fallback when APP_DATABASE_URL is absent.
# ---------------------------------------------------------------------------
APP_DATABASE_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL_DIRECT=postgresql://user:pass@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
DB_USER=nutree
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nutree

# ---------------------------------------------------------------------------
# DB connection mode
# direct_pool: app uses direct Neon URL + SQLAlchemy AsyncAdaptedQueuePool (default).
# neon_pooler: app uses Neon -pooler URL + NullPool (PgBouncer manages connections).
# Switch to neon_pooler and use a -pooler APP_DATABASE_URL only if you hit
# connection-explosion scenarios. Prepared statement caching is disabled automatically.
# ---------------------------------------------------------------------------
DB_CONNECTION_MODE=direct_pool

# ---------------------------------------------------------------------------
# Async connection pool tuning (direct_pool mode)
# total_capacity = UVICORN_WORKERS * (ASYNC_POOL_SIZE_PER_WORKER + ASYNC_POOL_MAX_OVERFLOW)
# ---------------------------------------------------------------------------
UVICORN_WORKERS=4
ASYNC_POOL_SIZE_PER_WORKER=3
ASYNC_POOL_MAX_OVERFLOW=2
ASYNC_POOL_TIMEOUT=10
ASYNC_POOL_RECYCLE=120
# Legacy aliases (still accepted but ASYNC_* takes precedence):
# POOL_SIZE_PER_WORKER=3
# POOL_MAX_OVERFLOW=2
# POOL_TIMEOUT=10

# ---------------------------------------------------------------------------
# Redis / cache
# CACHE_ENABLED=false disables optional Redis caches only.
# It does not add fallback for features that explicitly require Redis-backed state.
# ---------------------------------------------------------------------------
CACHE_ENABLED=true
CACHE_DEFAULT_TTL=3600
# Prefer REDIS_URL for hosted Redis (Upstash, Redis Cloud, etc.)
# Example (Upstash):
# REDIS_URL="rediss://default:YOUR_PASSWORD@sweeping-cattle-72925.upstash.io:6379"
REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_SSL=false
REDIS_MAX_CONNECTIONS=10

# ---------------------------------------------------------------------------
# Firebase (required for authentication)
# ---------------------------------------------------------------------------
GOOGLE_CLOUD_PROJECT=your-firebase-project-id
FIREBASE_CREDENTIALS=./firebase-service-account.json
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_PATH=./path/to/firebase-service-account.json
FCM_CREDENTIALS_PATH=./path/to/firebase-credentials.json

# ---------------------------------------------------------------------------
# AI provider routing
AI_PRIMARY_PROVIDER=openai
AI_FALLBACK_PROVIDER=cloudflare-workers-ai

# OpenAI provider (Responses API)
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-5.4-mini-2026-03-17
OPENAI_TEXT_MODEL=gpt-5.4-mini-2026-03-17
OPENAI_REQUEST_TIMEOUT_SECONDS=20
OPENAI_MAX_RETRIES=1
OPENAI_STORE_RESPONSES=false

# ---------------------------------------------------------------------------
# Cloudflare Workers AI — primary text-generation provider (LangChain-backed)
# Get credentials from https://dash.cloudflare.com → My Profile → API Tokens
# Cloudflare can be used as fallback for configured purposes.
# ---------------------------------------------------------------------------
CLOUDFLARE_WORKERS_AI_ENABLED=true
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
# Optional: AI Gateway ID for request logging/caching. Leave blank for direct Workers AI.
CLOUDFLARE_AI_GATEWAY_ID=
CLOUDFLARE_WORKERS_AI_TEXT_MODEL=@cf/meta/llama-3.3-70b-instruct-fp8-fast
CLOUDFLARE_WORKERS_AI_EMBEDDING_MODEL=@cf/google/embeddinggemma-300m
CLOUDFLARE_WORKERS_AI_EMBEDDING_DIMENSIONS=768
# Comma-separated purposes that use CF as fallback/alternate route.
CLOUDFLARE_WORKERS_AI_TEXT_PURPOSES=recipe,general,meal_names,discovery,parse_text
CLOUDFLARE_WORKERS_AI_TIMEOUT_SECONDS=60
# CF vision: set VISION_ENABLED=true to try Workers AI first for image scans.
# Rollback: set CLOUDFLARE_WORKERS_AI_VISION_ENABLED=false (no redeploy needed).
CLOUDFLARE_WORKERS_AI_VISION_ENABLED=true
CLOUDFLARE_WORKERS_AI_VISION_MODEL=@cf/google/gemma-4-26b-a4b-it
CLOUDFLARE_WORKERS_AI_VISION_PURPOSES=meal_scan,ingredient_scan
# ---------------------------------------------------------------------------
# DeepL Translation (required for non-English meal translation)
# Get from https://www.deepl.com/pro-api
# ---------------------------------------------------------------------------
DEEPL_API_KEY=

# ---------------------------------------------------------------------------
# Food Data APIs
# ---------------------------------------------------------------------------
# USDA FoodData Central (optional)
USDA_FDC_API_KEY=

# fatsecret API (barcode lookup + food search) — OAuth 2.0
FATSECRET_CLIENT_ID=
FATSECRET_CLIENT_SECRET=

# Brave Search API (web search for barcode nutrition) — free $5/mo credits
BRAVE_SEARCH_API_KEY=

# ---------------------------------------------------------------------------
# Image Storage (Cloudinary)
# Get from https://cloudinary.com/console
# ---------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---------------------------------------------------------------------------
# Image Search (for meal discovery photos)
# ---------------------------------------------------------------------------
PEXELS_API_KEY=
UNSPLASH_ACCESS_KEY=

# ---------------------------------------------------------------------------
# RevenueCat (in-app subscriptions)
# ---------------------------------------------------------------------------
REVENUECAT_SECRET_API_KEY=
REVENUECAT_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# PostHog (backend lifecycle analytics)
# ---------------------------------------------------------------------------
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com

# ---------------------------------------------------------------------------
# Email / SMTP configuration
# ---------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM_ADDRESS=
EMAIL_FROM_NAME=

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------
# ALLOWED_ORIGINS=http://localhost:3000,https://app.example.com

# ---------------------------------------------------------------------------
# File storage
# ---------------------------------------------------------------------------
UPLOADS_DIR=./uploads

# ---------------------------------------------------------------------------
# Feature flags / development toggles
# ---------------------------------------------------------------------------
USE_MOCK_STORAGE=0
DEV_USER_FIREBASE_UID=dev_firebase_uid
DEV_USER_EMAIL=dev@example.com
DEV_USER_USERNAME=dev_user

# ---------------------------------------------------------------------------
# AI Handshake Guest Trial
# HMAC-SHA256 secret for hashing guest install IDs before Postgres key storage.
# Must be a strong random secret in production. Empty = dev fallback used locally.
# ---------------------------------------------------------------------------
GUEST_INSTALL_HASH_SECRET=dev-hmac-secret-change-in-production

# ---------------------------------------------------------------------------
# Sentry observability (leave SENTRY_DSN empty to disable)
# ---------------------------------------------------------------------------
SENTRY_DSN=
SENTRY_RELEASE=
SENTRY_ENABLE_LOGS=true
SENTRY_ENABLE_METRICS=true
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.05
SENTRY_PROFILE_SESSION_SAMPLE_RATE=
SENTRY_PROFILE_LIFECYCLE=
SENTRY_SEND_PII=false

# ---------------------------------------------------------------------------
# Meal Image Cache (nightly-fill vector cache for food photos)
# ---------------------------------------------------------------------------
MEAL_IMAGE_CACHE_ENABLED=false
TEXT_DEDUP_THRESHOLD=0.65
IMAGE_MATCH_THRESHOLD=0.65
MEAL_IMAGE_COSINE_HIT_THRESHOLD=0.65

# Embeddings — SigLIP (768-d)
CLIP_MODEL_NAME=google/siglip-base-patch16-224
CLIP_DEVICE=cpu
CLIP_EMBEDDING_DIM=768

# Cloudflare Workers AI (for AI-generated food images)
# Get from https://dash.cloudflare.com → Workers & Pages → Overview
CF_ACCOUNT_ID=
CF_API_TOKEN=
CF_IMAGE_MODEL=@cf/black-forest-labs/flux-1-schnell
AI_IMAGE_TIMEOUT_SECONDS=60

# Nightly cron settings
MAX_JOBS_PER_CRON=50
CRON_EXTERNAL_CALL_DELAY_SECONDS=2.0
MAX_RESOLUTION_ATTEMPTS=5

# ---------------------------------------------------------------------------
# Meal Analysis Settings
# ---------------------------------------------------------------------------
MEAL_ANALYZE_MAX_ATTEMPTS=2
MEAL_ANALYZE_MAX_OUTPUT_TOKENS=700

# ---------------------------------------------------------------------------
# Referral System (Multi-Currency)
# ---------------------------------------------------------------------------
# Commission amounts per currency (JSON)
REFERRAL_COMMISSIONS={"USD":2,"VND":50000,"EUR":1.8,"default":2}
# Fixed exchange rates to VND for wallet conversion (JSON)
EXCHANGE_RATES_TO_VND={"USD":25000,"EUR":27000,"default":25000}
